ef\":\"/exercises/bands\",\"children\":[[\"$\",\"$L28\",null,{\"height\":361,\"width\":360,\"className\":\"rounded-xl\",\"src\":\"/routine_builder/equipment/bands.png\",\"alt\":\"bands group image\"}],[\"$\",\"p\",null,{\"children\":\"Bands\",\"data-slot\":\"text\",\"className\":\"text-base/[1.4] font-semibold text-jefit-blue text-center\"}]]}],[\"$\",\"$L27\",\"2\",{\"plain\":true,\"className\":\"border-2! border-transparent! flex shrink-0 flex-col justify-start! w-28 p-2! rounded-xl gap-2\",\"amplitudeEvent\":{\"event_type\":\"w-exercise-category-clicks\",\"event_properties\":{\"type\":\"equipment\",\"category\":\"barbell\"}},\"href\":\"/exercises/barbell\",\"children\":[[\"$\",\"$L28\",null,{\"height\":361,\"width\":360,\"className\":\"rounded-xl\",\"src\":\"/routine_builder/equipment/barbell.png\",\"alt\":\"barbell group image\"}],[\"$\",\"p\",null,{\"children\":\"Barbell\",\"data-slot\":\"text\",\"className\":\"text-base/[1.4] font-semibold text-jefit-blue text-center\"}]]}],[\"$\",\"$L27\",\"3\",{\"plain\":true,\"className\":\"border-2! border-transparent! flex shrink-0 flex-col justify-start! w-28 p-2! rounded-xl gap-2\",\"amplitudeEvent\":{\"event_type\":\"w-exercise-category-clicks\",\"event_properties\":{\"type\":\"equipment\",\"category\":\"bench\"}},\"href\":\"/exercises/bench\",\"children\":[[\"$\",\"$L28\",null,{\"height\":361,\"width\":360,\"className\":\"rounded-xl\",\"src\":\"/routine_builder/equipment/bench.png\",\"alt\":\"bench group image\"}],[\"$\",\"p\",null,{\"children\":\"Bench\",\"data-slot\":\"text\",\"className\":\"text-base/[1.4] font-semibold text-jefit-blue text-center\"}]]}],[\"$\",\"$L27\",\"4\",{\"plain\":true,\"className\":\"border-2! border-transparent! flex shrink-0 flex-col justify-start! w-28 p-2! rounded-xl gap-2\",\"amplitudeEvent\":{\"event_type\":\"w-exercise-category-clicks\",\"event_properties\":{\"type\":\"equipment\",\"category\":\"dumbbell\"}},\"href\":\"/exercises/dumbbell\",\"children\":[[\"$\",\"$L28\",null,{\"height\":361,\"width\":360,\"className\":\"rounded-xl\",\"src\":\"/routine_builder/equipment/dumbbell.png\",\"alt\":\"dumbbell group image\"}],[\"$\",\"p\",null,{\"children\":\"Dumbbell\",\"data-slot\":\"text\",\"className\":\"text-base/[1.4] font-semibold text-jefit-blue text-center\"}]]}],[\"$\",\"$L27\",\"5\",{\"plain\":true,\"className\":\"border-2! border-transparent! flex shrink-0 flex-col justify-start! w-28 p-2! rounded-xl gap-2\",\"amplitudeEvent\":{\"event_type\":\"w-exercise-category-clicks\",\"event_properties\":{\"type\":\"equipment\",\"category\":\"exercise_ball\"}},\"href\":\"/exercises/exercise_ball\",\"children\":[[\"$\",\"$L28\",null,{\"height\":361,\"width\":360,\"className\":\"rounded-xl\",\"src\":\"/routine_builder/equipment/exercise_ball.png\",\"alt\":\"exercise_ball group image\"}],[\"$\",\"p\",null,{\"children\":\"Exercise Ball\",\"data-slot\":\"text\",\"className\":\"text-base/[1.4] font-semibold text-jefit-blue text-center\"}]]}],[\"$\",\"$L27\",\"6\",{\"plain\":true,\"className\":\"border-2! border-transparent! flex shrink-0 flex-col justify-start! w-28 p-2! rounded-xl gap-2\",\"amplitudeEvent\":{\"event_type\":\"w-exercise-category-clicks\",\"event_properties\":{\"type\":\"equipment\",\"category\":\"ez_curl_bar\"}},\"href\":\"/exercises/ez_curl_bar\",\"children\":[[\"$\",\"$L28\",null,{\"height\":361,\"width\":360,\"className\":\"rounded-xl\",\"src\":\"/routine_builder/equipment/ez_curl_bar.png\",\"alt\":\"ez_curl_bar group image\"}],\"$L3a\"]}],\"$L3b\",\"$L3c\",\"$L3d\",\"$L3e\",\"$L3f\"]}]]}]\n"])</script><script>self.__next_f.push([1,"3a:[\"$\",\"p\",null,{\"children\":\"EZ Curl Bar\",\"data-slot\":\"text\",\"className\":\"text-base/[1.4] font-semibold text-jefit-blue text-center\"}]\n3b:[\"$\",\"$L27\",\"7\",{\"plain\":true,\"className\":\"border-2! border-transparent! flex shrink-0 flex-col justify-start! w-28 p-2! rounded-xl gap-2\",\"amplitudeEvent\":{\"event_type\":\"w-exercise-category-clicks\",\"event_properties\":{\"type\":\"equipment\",\"category\":\"kettlebell\"}},\"href\":\"/exercises/kettlebell\",\"children\":[[\"$\",\"$L28\",null,{\"height\":361,\"width\":360,\"className\":\"rounded-xl\",\"src\":\"/routine_builder/equipment/kettlebell.png\",\"alt\":\"kettlebell group image\"}],[\"$\",\"p\",null,{\"children\":\"Kettlebell\",\"data-slot\":\"text\",\"className\":\"text-base/[1.4] font-semibold text-jefit-blue text-center\"}]]}]\n3c:[\"$\",\"$L27\",\"8\",{\"plain\":true,\"className\":\"border-2! border-transparent! flex shrink-0 flex-col justify-start! w-28 p-2! rounded-xl gap-2\",\"amplitudeEvent\":{\"event_type\":\"w-exercise-category-clicks\",\"event_properties\":{\"type\":\"equipment\",\"category\":\"machine_cardio\"}},\"href\":\"/exercises/machine_cardio\",\"children\":[[\"$\",\"$L28\",null,{\"height\":361,\"width\":360,\"className\":\"rounded-xl\",\"src\":\"/routine_builder/equipment/machine_cardio.png\",\"alt\":\"machine_cardio group image\"}],[\"$\",\"p\",null,{\"children\":\"Cardio Machine\",\"data-slot\":\"text\",\"className\":\"text-base/[1.4] font-semibold text-jefit-blue text-center\"}]]}]\n3d:[\"$\",\"$L27\",\"9\",{\"plain\":true,\"className\":\"border-2! border-transparent! flex shrink-0 flex-col justify-start! w-28 p-2! rounded-xl gap-2\",\"amplitudeEvent\":{\"event_type\":\"w-exercise-category-clicks\",\"event_properties\":{\"type\":\"equipment\",\"category\":\"machine_strength\"}},\"href\":\"/exercises/machine_strength\",\"children\":[[\"$\",\"$L28\",null,{\"height\":361,\"width\":360,\"className\":\"rounded-xl\",\"src\":\"/routine_builder/equipment/machine_strength.png\",\"alt\":\"machine_strength group image\"}],[\"$\",\"p\",null,{\"children\":\"Strength Machine\",\"data-slot\":\"text\",\"className\":\"text-base/[1.4] font-semibold text-jefit-blue text-center\"}]]}]\n3e:[\"$\",\"$L27\",\"10\",{\"plain\":true,\"className\":\"border-2! border-transparent! flex shrink-0 flex-col justify-start! w-28 p-2! rounded-xl gap-2\",\"amplitudeEvent\":{\"event_type\":\"w-exercise-category-clicks\",\"event_properties\":{\"type\":\"equipment\",\"category\":\"pullup_bar\"}},\"href\":\"/exercises/pullup_bar\",\"children\":[[\"$\",\"$L28\",null,{\"height\":361,\"width\":360,\"className\":\"rounded-xl\",\"src\":\"/routine_builder/equipment/pullup_bar.png\",\"alt\":\"pullup_bar group image\"}],[\"$\",\"p\",null,{\"children\":\"Pullup Bar\",\"data-slot\":\"text\",\"className\":\"text-base/[1.4] font-semibold text-jefit-blue text-center\"}]]}]\n3f:[\"$\",\"$L27\",\"11\",{\"plain\":true,\"className\":\"border-2! border-transparent! flex shrink-0 flex-col justify-start! w-28 p-2! rounded-xl gap-2\",\"amplitudeEvent\":{\"event_type\":\"w-exercise-category-clicks\",\"event_properties\":{\"type\":\"equipment\",\"category\":\"weight_plate\"}},\"href\":\"/exercises/weight_plate\",\"children\":[[\"$\",\"$L28\",null,{\"height\":361,\"width\":360,\"className\":\"rounded-xl\",\"src\":\"/routine_builder/equipment/weight_plate.png\",\"alt\":\"weight_plate group image\"}],[\"$\",\"p\",null,{\"children\":\"Weight Plate\",\"data-slot\":\"text\",\"className\":\"text-base/[1.4] font-semibold text-jefit-blue text-center\"}]]}]\n1d:[[\"$\",\"meta\",\"0\",{\"charSet\":\"utf-8\"}],[\"$\",\"meta\",\"1\",{\"name\":\"viewport\",\"content\":\"width=device-width, initial-scale=1\"}]]\n41:T6be,"])</script><script>self.__next_f.push([1,"The weight plate wall sit is a variation of the traditional wall sit exercise that adds resistance to increase the challenge for your lower body muscles, particularly the quadriceps, hamstrings, and glutes.\r\n\r\nStand with your back pressed firmly against the wall. Walk your feet out and slide your back down the wall until your knees are bent at a 90-degree angle, or as close to 90 degrees as possible. Your feet should be positioned slightly wider than shoulder-width apart, and your knees should be aligned with your ankles.\r\n\r\nWith your hands gripping the weight plate in front of your chest, keep your elbows bent and close to your body.\r\nEnsure that the weight plate is held securely and does not slip during the exercise. Brace your core muscles to stabilize your spine and maintain proper posture throughout the exercise.\r\n\r\nHold the wall sit position with your knees bent at a 90-degree angle and your back pressed against the wall.\r\nKeep your chest lifted, shoulders back, and gaze straight ahead.\r\nEnsure that your weight is distributed evenly through your feet, with the majority of the pressure on your heels.\r\n\r\nHold the wall sit position for a predetermined amount of time, such as 20-30 seconds, or longer if you're more advanced. Focus on breathing steadily throughout the hold, inhaling through your nose and exhaling through your mouth.\r\n\r\nAfter completing the hold, slowly push through your heels and straighten your legs to return to the standing position against the wall. Keep your back pressed against the wall as you rise up. Take a short rest period before repeating the exercise for additional sets or hold times. Aim to perform 2-3 sets of wall sits, holding each position for the desired duration."])</script><script>self.__next_f.push([1,"42:T691,"])</script><script>self.__next_f.push([1,"Performing front-to-back leg swings is an excellent dynamic warm-up exercise that helps to increase flexibility, mobility, and blood flow to the lower body.\r\n\r\nStand tall with your feet hip-width apart and your arms relaxed by your sides. Engage your core muscles by gently pulling your belly button towards your spine to stabilize your torso. If needed, you can use a wall or a sturdy object for support to maintain your balance during the exercise.\r\n\r\nBegin by swinging one leg forward in a controlled motion. Keep your knee straight but not locked. Swing your leg as high as comfortable, aiming for a gentle stretch in the hamstrings. After swinging your leg forward, smoothly swing it backward in the opposite direction. Again, keep your knee straight but not locked, and aim for a gentle stretch in the quadriceps by bending the knee, trying to kick your buttock with your heel.\r\n\r\nFocus on maintaining control throughout the movement. Avoid swinging your leg too forcefully or using momentum to lift it. The motion should be controlled and deliberate. After completing the desired number of repetitions on one leg, switch to the other leg and repeat the exercise.\r\n\r\nWhile swinging your legs, keep your upper body stable and avoid leaning excessively forward or backward. Your torso should remain upright throughout the exercise. Coordinate your breathing with the movement. Inhale as you swing your leg forward, and exhale as you swing it backward.\r\n\r\nGradually Increase Range of Motion: As you warm up, gradually increase the range of motion of your leg swings. Try to swing your leg higher with each repetition, but only go as far as you can comfortably without straining."])</script><script>self.__next_f.push([1,"2a:[\"$\",\"div\",null,{\"className\":\"lg:flex hidden w-full text-center mt-10\",\"children\":[\"$\",\"$L40\",null,{\"exercises\":[{\"id\":\"d_000000000217\",\"name\":\"Machine Hip Adduction\",\"input_format\":\"weight_and_reps\",\"description\":\"The thigh adductor exercise targets and works the muscles of the inner thighs\\r\\n\\r\\nSteps :\\r\\n\\r\\n1.) Start by sitting on a hip adductor machine resting your knees against the pads.\\r\\n\\r\\n2.) Draw your abs in and adduct or move your thighs together using the pads bringing thighs together.\\r\\n\\r\\n3.) Slowly return to the starting position and repeat.\",\"type\":\"strength\",\"difficulty\":\"beginner\",\"popularity\":\"52388\",\"media\":{\"image_urls\":[\"https://www.jefit.com/images/exercises/960_590/868.jpg\",\"https://www.jefit.com/images/exercises/960_590/869.jpg\",\"https://www.jefit.com/images/exercises/960_590/870.jpg\",\"https://www.jefit.com/images/exercises/960_590/871.jpg\"]},\"body_parts\":[\"upper_legs\",\"none\",\"none\",\"hamstrings\",\"quads\"],\"equipment\":[\"machine_strength\",\"none\"]},{\"id\":\"d_000000001211\",\"name\":\"Stability Ball Weighted Wall Squat\",\"input_format\":\"weight_and_reps\",\"description\":\"Steps :\\r\\n\\r\\n1.) Start by setting up an exercise ball against the wall, leaning your back up against the ball so it is positioned in the middle of your body and holding a dumbbell in each hand.\\r\\n\\r\\n2.) Slowly lower your body towards the ground so that your thighs are parallel with the ground, so your upper back and head are rested on the exercise ball.\\r\\n\\r\\n3.) Hold for a count then return back to the starting position.\\r\\n\\r\\n4.) Repeat for as many reps and sets as desired.\",\"type\":\"strength\",\"difficulty\":\"intermediate\",\"popularity\":\"163\",\"media\":{\"image_urls\":[\"https://www.jefit.com/images/exercises/960_590/4844.jpg\",\"https://www.jefit.com/images/exercises/960_590/4845.jpg\",\"https://www.jefit.com/images/exercises/960_590/4846.jpg\",\"https://www.jefit.com/images/exercises/960_590/4847.jpg\"]},\"body_parts\":[\"upper_legs\",\"glutes\",\"lower_legs\",\"none\",\"none\"],\"equipment\":[\"exercise_ball\",\"none\"]},{\"id\":\"d_000000001199\",\"name\":\"Hack Squat (Reverse Position)\",\"input_format\":\"weight_and_reps\",\"description\":\"Steps :\\r\\n\\r\\n1.) Start by setting up the hack squat machine with the amount of weight that you would like to perform for this exercise and then place yourself with your chest flat on the pad and shoulders up against the shoulder rests.\\r\\n\\r\\n2.) Push up with your body to remove the weights up off of the stacks and place your arms on the side handles as this will be your starting position.\\r\\n\\r\\n3.) Slowly lower the weight down until your thighs create right angles with your calves and hold for a count.\\r\\n\\r\\n4.) Return back to the starting position.\\r\\n\\r\\n5.) Repeat for as many reps and sets as desired.\",\"type\":\"strength\",\"difficulty\":\"intermediate\",\"popularity\":\"2866\",\"media\":{\"image_urls\":[\"https://www.jefit.com/images/exercises/960_590/4796.jpg\",\"https://www.jefit.com/images/exercises/960_590/4797.jpg\",\"https://www.jefit.com/images/exercises/960_590/4798.jpg\",\"https://www.jefit.com/images/exercises/960_590/4799.jpg\"]},\"body_parts\":[\"upper_legs\",\"glutes\",\"lower_legs\",\"none\",\"none\"],\"equipment\":[\"machine_strength\",\"none\"]},{\"id\":\"d_000000000127\",\"name\":\"Hack Squat\",\"input_format\":\"weight_and_reps\",\"description\":\"The hack squat exercise is a variation of the squat workout which uses a machine in place of squat rack and may be preferred by beginners.\\r\\n\\r\\nSteps : \\r\\n\\r\\n1.) Start off lying face up on a hack squat machine with your shoulders up against the pad, placing your feet forward at a slightly less than shoulder-width apart and toes pointed slightly outward as this will be your starting position.\\r\\n\\r\\n2.) Once in position, release the dock levers, place your hands on the grips, keep your abs tightly drawn in and extend your body so that you are standing upright.\\r\\n\\r\\n3.) Slowly lower your body down into a squatting position so that your knees are bent and you feel a stretch in your quad and hamstring muscles.\\r\\n\\r\\n4.) Hold for a count and then return back to the starting position.\\r\\n\\r\\n5.) Repeat for as many reps and sets as desired.\",\"type\":\"strength\",\"difficulty\":\"beginner\",\"popularity\":\"27025\",\"media\":{\"image_urls\":[\"https://www.jefit.com/images/exercises/960_590/508.jpg\",\"https://www.jefit.com/images/exercises/960_590/509.jpg\",\"https://www.jefit.com/images/exercises/960_590/510.jpg\",\"https://www.jefit.com/images/exercises/960_590/511.jpg\"]},\"body_parts\":[\"upper_legs\",\"glutes\",\"hamstrings\",\"abs\",\"lower_back\"],\"equipment\":[\"machine_strength\",\"none\"]},{\"id\":\"d_000000000497\",\"name\":\"Weight Plate Squat\",\"input_format\":\"weight_and_reps\",\"description\":\"Steps :\\r\\n\\r\\n1.) To begin this exercise; start off by taking two flat benches and positioning them shoulder length apart and standing on top of them with a weighted plate attached to your torso right above the opening between both benches.\\r\\n\\r\\n2.) Then bend at your knees keeping a straight posture with your back straight and chest out continuing down until your upper legs and knees form a 90-degree angle and the weight plate falling in between both of the benches. Hold for a few seconds.\\r\\n\\r\\n3.) Use your lower legs as well as your heels to push yourself back up.\\r\\n\\r\\n4.) Return back to the starting position.\\r\\n\\r\\n5.) Repeat this exercise for as many repetitions as needed\",\"type\":\"strength\",\"difficulty\":\"intermediate\",\"popularity\":\"359\",\"media\":{\"image_urls\":[\"https://www.jefit.com/images/exercises/960_590/1988.jpg\",\"https://www.jefit.com/images/exercises/960_590/1989.jpg\",\"https://www.jefit.com/images/exercises/960_590/1990.jpg\",\"https://www.jefit.com/images/exercises/960_590/1991.jpg\"]},\"body_parts\":[\"upper_legs\",\"lower_legs\",\"glutes\",\"hamstrings\",\"quads\"],\"equipment\":[\"weight_plate\",\"none\"]},{\"id\":\"d_000000000482\",\"name\":\"Kettlebell Single-Leg Deadlift\",\"input_format\":\"weight_and_reps\",\"description\":\"Steps : \\r\\n\\r\\n1.) To begin this exercise; start off by holding a kettlebell in on hand and then stand on one leg as the same as the hand that holds the kettlebell.\\r\\n\\r\\n2.) From that position perform a stiff legged deadlift by bending at the hip and pushing your alternate leg straight out behind you.\\r\\n\\r\\n3.) Lower the kettlebell until it touches the floor and hold for a few seconds.\\r\\n\\r\\n4.) Return back to the starting position.\\r\\n\\r\\n5.) Repeat this exercise for as many repetitions as needed\",\"type\":\"strength\",\"difficulty\":\"intermediate\",\"popularity\":\"6096\",\"media\":{\"image_urls\":[\"https://www.jefit.com/images/exercises/960_590/1928.jpg\",\"https://www.jefit.com/images/exercises/960_590/1929.jpg\",\"https://www.jefit.com/images/exercises/960_590/1930.jpg\",\"https://www.jefit.com/images/exercises/960_590/1931.jpg\"]},\"body_parts\":[\"upper_legs\",\"glutes\",\"back\",\"hamstrings\",\"quads\"],\"equipment\":[\"kettlebell\",\"none\"]},{\"id\":\"d_000000000203\",\"name\":\"Smith Machine Hack Squat\",\"input_format\":\"weight_and_reps\",\"description\":\"The smith machine hack squat exercise is a variation of the basic squat that focuses on strengthening and building the quadricep muscle.\\r\\n\\r\\nSteps : \\r\\n\\r\\n1.) Start by adjusting the bar on the smith machine to a low setting just above your ankles.\\r\\n\\r\\n2.) Stand with the bar on the floor just behind your legs, with your feet shoulder width apart and your toes pointing forward\\r\\n\\r\\n3.) With your feet firmly placed on the floor reach down and grasp the bar from behind with and overhand grip.\\r\\n\\r\\n4.) Lift the bar by extending your hips and knees, be careful not to lock your knees.\\r\\n\\r\\n5.) Squat down until your thighs are parallel to the floor and hold the position for a count.\\r\\n\\r\\n6.) Slowly raise yourself up to starting position.\\r\\n\\r\\n7.) Repeat for as many reps and sets as desired.\",\"type\":\"strength\",\"difficulty\":\"beginner\",\"popularity\":\"353\",\"media\":{\"image_urls\":[\"https://www.jefit.com/images/exercises/960_590/812.jpg\",\"https://www.jefit.com/images/exercises/960_590/813.jpg\",\"https://www.jefit.com/images/exercises/960_590/814.jpg\",\"https://www.jefit.com/images/exercises/960_590/815.jpg\"]},\"body_parts\":[\"upper_legs\",\"glutes\",\"none\",\"hamstrings\",\"quads\"],\"equipment\":[\"machine_strength\",\"none\"]},{\"id\":\"d_000000000897\",\"name\":\"Box Jump Multiple Response\",\"input_format\":\"reps\",\"description\":\"Steps :\\r\\n\\r\\n1.) Place a box, that is about 2 feet tall, in front of you and stand about arms length away.\\r\\n\\r\\n2.) Slightly bend down at the knees with your arms at your sides and with as much force as you can, jump up and forward onto the box landing with both feet.\\r\\n\\r\\n3.) As soon as you land immediately drop down to the original starting position.\\r\\n\\r\\n4.) Repeat for as many reps and sets as desired.\",\"type\":\"strength\",\"difficulty\":\"intermediate\",\"popularity\":\"389\",\"media\":{\"image_urls\":[\"https://www.jefit.com/images/exercises/960_590/3588.jpg\",\"https://www.jefit.com/images/exercises/960_590/3589.jpg\",\"https://www.jefit.com/images/exercises/960_590/3590.jpg\",\"https://www.jefit.com/images/exercises/960_590/3591.jpg\"]},\"body_parts\":[\"upper_legs\",\"lower_legs\",\"none\",\"hamstrings\",\"quads\"],\"equipment\":[\"plyo_box\",\"none\"]},{\"id\":\"d_000000000205\",\"name\":\"Barbell Bulgarian Split Squat\",\"input_format\":\"weight_and_reps\",\"description\":\"The barbell single-leg squat exercise is an advanced exercise that works on strengthening the muscles in hip and leg while improving core strength and coordination.\\r\\n\\r\\nSteps : \\r\\n\\r\\n1.) Start by placing a barbell on your back above your shoulders with a wide grip.\\r\\n\\r\\n2.) Place one foot behind you resting it on a bench.\\r\\n\\r\\n3.) Slowly lower down until you're about parallel to the floor with the involved leg. \\r\\n\\r\\n4.) Slowly return to an upright position focusing on your hip and thigh.\\r\\n\\r\\n5.) Switch legs and repeat for as many reps and sets as desired.\",\"type\":\"strength\",\"difficulty\":\"intermediate\",\"popularity\":\"5978\",\"media\":{\"image_urls\":[\"https://www.jefit.com/images/exercises/960_590/820.jpg\",\"https://www.jefit.com/images/exercises/960_590/821.jpg\",\"https://www.jefit.com/images/exercises/960_590/822.jpg\",\"https://www.jefit.com/images/exercises/960_590/823.jpg\"]},\"body_parts\":[\"upper_legs\",\"glutes\",\"quads\",\"calves\",\"none\"],\"equipment\":[\"barbell\",\"none\"]},{\"id\":\"d_000000001206\",\"name\":\"Single-Leg Squat\",\"input_format\":\"weight_and_reps\",\"description\":\"Steps :\\r\\n\\r\\n1.) Start by setting up a horizontal flat bench behind you and placing one of your legs behind you in the middle of the bench as this will be your starting position.\\r\\n\\r\\n2.) Cross your arms in front of you and slowly lower your body down towards the floor, bending with your front leg until your knee is parallel with the floor and hold for a count.\\r\\n\\r\\n3.) Return back to the starting position.\\r\\n\\r\\n4.) Repeat for as many reps and sets as desired.\",\"type\":\"strength\",\"difficulty\":\"beginner\",\"popularity\":\"652\",\"media\":{\"image_urls\":[\"https://www.jefit.com/images/exercises/960_590/4824.jpg\",\"https://www.jefit.com/images/exercises/960_590/4825.jpg\",\"https://www.jefit.com/images/exercises/960_590/4826.jpg\",\"https://www.jefit.com/images/exercises/960_590/4827.jpg\"]},\"body_parts\":[\"upper_legs\",\"glutes\",\"lower_legs\",\"none\",\"none\"],\"equipment\":[\"body\",\"none\"]},{\"id\":\"d_000000001384\",\"name\":\"Weight Plate Wall Sit\",\"input_format\":\"duration\",\"description\":\"$41\",\"type\":\"strength\",\"difficulty\":\"intermediate\",\"popularity\":\"1408\",\"media\":{\"image_urls\":[\"https://www.jefit.com/images/exercises/960_590/5536.jpg\",\"https://www.jefit.com/images/exercises/960_590/5537.jpg\",\"https://www.jefit.com/images/exercises/960_590/5538.jpg\",\"https://www.jefit.com/images/exercises/960_590/5539.jpg\"]},\"body_parts\":[\"upper_legs\",\"lower_chest\",\"glutes\",\"none\",\"none\"],\"equipment\":[\"weight_plate\",\"none\"]},{\"id\":\"d_000000001215\",\"name\":\"Bodyweight Lunge\",\"input_format\":\"reps\",\"description\":\"Steps :\\r\\n\\r\\n1.) Start by standing up straight with your knees slightly bent then get into a lunge position, and squat down through your hips.\\r\\n\\r\\n2.) Squat down so that your front leg is parallel with the floor and hold for a count.\\r\\n\\r\\n3.) Return back to the starting position.\\r\\n\\r\\n4.) Repeat for as many reps and sets as desired.\\r\\n\",\"type\":\"strength\",\"difficulty\":\"intermediate\",\"popularity\":\"5483\",\"media\":{\"image_urls\":[\"https://www.jefit.com/images/exercises/960_590/4860.jpg\",\"https://www.jefit.com/images/exercises/960_590/4861.jpg\",\"https://www.jefit.com/images/exercises/960_590/4862.jpg\",\"https://www.jefit.com/images/exercises/960_590/4863.jpg\"]},\"body_parts\":[\"upper_legs\",\"glutes\",\"lower_legs\",\"none\",\"none\"],\"equipment\":[\"body\",\"none\"]},{\"id\":\"d_000000001256\",\"name\":\"Machine Single-Leg Extension \",\"input_format\":\"weight_and_reps\",\"description\":\"Steps :\\r\\n\\r\\n1.) Start by sitting on a leg extension machine, with both legs rested underneath the padding and your back flat on the rest behind you.\\r\\n\\r\\n2.) Slowly, while keeping your upper body still, elevate the padding up with just one of your legs, keeping the other still in the starting position.\\r\\n\\r\\n3.) Squeeze with your quads and hamstrings on the way up, going up as far as possible and hold for a count.\\r\\n\\r\\n4.) Return back to the starting position.\\r\\n\\r\\n5.) Repeat for as many reps and sets as desired.\",\"type\":\"strength\",\"difficulty\":\"beginner\",\"popularity\":\"13111\",\"media\":{\"image_urls\":[\"https://www.jefit.com/images/exercises/960_590/5024.jpg\",\"https://www.jefit.com/images/exercises/960_590/5025.jpg\"]},\"body_parts\":[\"upper_legs\",\"none\",\"none\",\"none\",\"none\"],\"equipment\":[\"machine_strength\",\"none\"]},{\"id\":\"d_000000000909\",\"name\":\"Hamstring Stretch\",\"input_format\":\"reps_and_duration\",\"description\":\"Steps :\\r\\n\\r\\n1.) Start off laying flat on your back with one knee bent and the other foot extended out to stabilize your body.\\r\\n\\r\\n2.) With the bent leg, extend it up in the air so that the sole of your foot is pointed up in the air, placing your clasped hands around the extended leg for support.\\r\\n\\r\\n3.) Straighten out the leg as much as possible feeling a stretch in your hamstrings, then try to pull it as close as you can towards your nose.\\r\\n\\r\\n4.) Hold this position for 15 to 30 seconds then return back to the starting position.\\r\\n\\r\\n5.) Repeat for as many reps and sets as desired.\",\"type\":\"stretching\",\"difficulty\":\"beginner\",\"popularity\":\"1194\",\"media\":{\"image_urls\":[\"https://www.jefit.com/images/exercises/960_590/3636.jpg\",\"https://www.jefit.com/images/exercises/960_590/3637.jpg\",\"https://www.jefit.com/images/exercises/960_590/3638.jpg\",\"https://www.jefit.com/images/exercises/960_590/3639.jpg\"]},\"body_parts\":[\"upper_legs\",\"none\",\"none\",\"none\",\"none\"],\"equipment\":[\"body\",\"none\"]},{\"id\":\"d_000000000201\",\"name\":\"Dumbbell Walking Lunge\",\"input_format\":\"weight_and_reps\",\"description\":\"The dumbbell walking lunge exercise helps strengthen the leg and core muscles through constant motion.\\r\\n\\r\\nSteps : \\r\\n\\r\\n1.) Start off by either placing a barbell across your upper back or by grasping a dumbbell in each hand.\\r\\n\\r\\n2.) Stand with your feet about 8 inches apart, toes facing forward.\\r\\n\\r\\n3.) Take a lunge forward keeping your abs drawn in and your upper body straight.\\r\\n\\r\\n4.) Slowly lower one knee down as if kneeling while keeping your other knee bent at a 90 degree angle.\\r\\n\\r\\n5.) Lower your body to just above the floor and hold for a moment before pushing off with the back foot.\\r\\n\\r\\n6.) Step through and repeat the exercise with the other leg.\\r\\n\\r\\nTips :\\r\\n\\r\\n1.) Refrain from touching your knee to the ground.\",\"type\":\"strength\",\"difficulty\":\"intermediate\",\"popularity\":\"13090\",\"media\":{\"image_urls\":[\"https://www.jefit.com/images/exercises/960_590/804.jpg\",\"https://www.jefit.com/images/exercises/960_590/805.jpg\",\"https://www.jefit.com/images/exercises/960_590/806.jpg\",\"https://www.jefit.com/images/exercises/960_590/807.jpg\"]},\"body_parts\":[\"upper_legs\",\"glutes\",\"lower_legs\",\"hamstrings\",\"quads\"],\"equipment\":[\"dumbbell\",\"none\"]},{\"id\":\"d_000000000579\",\"name\":\"Forward Step-Up\",\"input_format\":\"reps\",\"description\":\"Steps :\\r\\n\\r\\n1.) Begin by facing the side of a box or bench with your feet shoulder width apart and feet straight ahead, keeping your hands on your hips.\\r\\n\\r\\n2.) Step up and forward with one foot on the box, the with your opposite hip step up with the other foot.\\r\\n\\r\\n3.) While holding your hips, step back down and repeat this motion for as many time as possible.\",\"type\":\"strength\",\"difficulty\":\"beginner\",\"popularity\":\"247\",\"media\":{\"image_urls\":[\"https://www.jefit.com/images/exercises/960_590/2316.jpg\",\"https://www.jefit.com/images/exercises/960_590/2317.jpg\",\"https://www.jefit.com/images/exercises/960_590/2318.jpg\",\"https://www.jefit.com/images/exercises/960_590/2319.jpg\"]},\"body_parts\":[\"upper_legs\",\"glutes\",\"abs\",\"none\",\"none\"],\"equipment\":[\"bench\",\"none\"]},{\"id\":\"d_000000001216\",\"name\":\"Single-Leg Hack Squat\",\"input_format\":\"weight_and_reps\",\"description\":\"Steps :\\r\\n\\r\\n1.) Start by setting up a hack squat machine with the weight that you would like to perform for this exercise, placing your back on the pad and your shoulders up against the shoulder pads.\\r\\n\\r\\n2.) Place your feet on the platform then lift your right foot off of the platform and extend your left leg in front of you.\\r\\n\\r\\n3.) Push the weight up off of the stack, place your hands on the handles of the machine and this will be your starting position.\\r\\n\\r\\n4.) Slowly lower the weight down until your left thigh is parallel with the ground and your calf muscle and hold for a count.\\r\\n\\r\\n5.) Return back to the starting position.\\r\\n\\r\\n6.) Repeat for as many reps and sets as desired.\",\"type\":\"strength\",\"difficulty\":\"intermediate\",\"popularity\":\"286\",\"media\":{\"image_urls\":[\"https://www.jefit.com/images/exercises/960_590/4864.jpg\",\"https://www.jefit.com/images/exercises/960_590/4865.jpg\"]},\"body_parts\":[\"upper_legs\",\"glutes\",\"lower_legs\",\"none\",\"none\"],\"equipment\":[\"machine_strength\",\"none\"]},{\"id\":\"d_000000000483\",\"name\":\"Kettlebell Pistol Squat\",\"input_format\":\"weight_and_reps\",\"description\":\"Steps : \\r\\n\\r\\n1.) To begin this exercise; start off by picking up a kettlebell with two hands and holding it against your chest right below your neck.\\r\\n\\r\\n2.) Take one leg and hold it off of the floor and with the other leg begin to squat down and bend at the knee.\\r\\n\\r\\n3.) While squatting down hold the kettlebell in front of your chest and hold the position when you get close to the ground.\\r\\n\\r\\n4.) Using the force from your heel push yourself back up.\\r\\n\\r\\n5.) Return back to the starting position.\\r\\n\\r\\n6.) Repeat this exercise for as many repetitions as needed\",\"type\":\"strength\",\"difficulty\":\"advanced\",\"popularity\":\"809\",\"media\":{\"image_urls\":[\"https://www.jefit.com/images/exercises/960_590/1932.jpg\",\"https://www.jefit.com/images/exercises/960_590/1933.jpg\",\"https://www.jefit.com/images/exercises/960_590/1934.jpg\",\"https://www.jefit.com/images/exercises/960_590/1935.jpg\"]},\"body_parts\":[\"upper_legs\",\"shoulders\",\"glutes\",\"hamstrings\",\"quads\"],\"equipment\":[\"kettlebell\",\"none\"]},{\"id\":\"d_000000000916\",\"name\":\"Half Locust\",\"input_format\":\"reps_and_duration\",\"description\":\"Steps :\\r\\n\\r\\n1.) Start by laying face down on the floor, placing a hand under your left hipbone and then bending your right knee back so that you are able to grab it with your right hand.\\r\\n\\r\\n2.) Slowly lift your right foot up into the air as you lift your shoulders off of the floor and grab your right foot with your right hand.\\r\\n\\r\\n3.) Pull back on the foot so that it stretches out your right hip flexor.\\r\\n\\r\\n4.) Hold this position for 15 to 30 seconds then return back to the starting position.\\r\\n\\r\\n5.) Repeat for as many reps, sets and duration as desired.\",\"type\":\"stretching\",\"difficulty\":\"beginner\",\"popularity\":\"84\",\"media\":{\"image_urls\":[\"https://www.jefit.com/images/exercises/960_590/3664.jpg\",\"https://www.jefit.com/images/exercises/960_590/3665.jpg\",\"https://www.jefit.com/images/exercises/960_590/3666.jpg\",\"https://www.jefit.com/images/exercises/960_590/3667.jpg\"]},\"body_parts\":[\"upper_legs\",\"abs\",\"chest\",\"none\",\"none\"],\"equipment\":[\"body\",\"none\"]},{\"id\":\"d_000000000131\",\"name\":\"Dumbbell Squat\",\"input_format\":\"weight_and_reps\",\"description\":\"The dumbbell squat exercise is a great workout for the lower body and uses dumbbells instead of a barbell to complete the motion.\\r\\n\\r\\nSteps : \\r\\n\\r\\n1.) Start off grabbing a dumbbell in each hand, placing your feet slightly wider than shoulder-width apart with your knees and toes pointed outward.\\r\\n\\r\\n2.) Keeping your abs tightly drawn in, slowly descend by bending at your knees and hips in a squatting motion.\\r\\n\\r\\n3.) Continue to slowly lower yourself as far as you can control without letting your body shift towards your toes.\\r\\n\\r\\n4.) Once in the downward position and as far as you can go down, hold for a count and then slowly return to the starting position.\\r\\n\\r\\n5.) Repeat for as many reps and sets as desired.\\r\\n\\r\\n\",\"type\":\"strength\",\"difficulty\":\"beginner\",\"popularity\":\"18648\",\"media\":{\"image_urls\":[\"https://www.jefit.com/images/exercises/960_590/524.jpg\",\"https://www.jefit.com/images/exercises/960_590/525.jpg\",\"https://www.jefit.com/images/exercises/960_590/526.jpg\",\"https://www.jefit.com/images/exercises/960_590/527.jpg\"]},\"body_parts\":[\"upper_legs\",\"lower_legs\",\"glutes\",\"hamstrings\",\"quads\"],\"equipment\":[\"dumbbell\",\"none\"]},{\"id\":\"d_000000001419\",\"name\":\"Front to Back Leg Swings\",\"input_format\":\"reps_and_duration\",\"description\":\"$42\",\"type\":\"dynamic\",\"difficulty\":\"beginner\",\"popularity\":\"1379\",\"media\":{\"image_urls\":[\"https://www.jefit.com/images/exercises/960_590/5676.jpg\",\"https://www.jefit.com/images/exercises/960_590/5677.jpg\",\"https://www.jefit.com/images/exercises/960_590/5678.jpg\",\"https://www.jefit.com/images/exercises/960_590/5679.jpg\"]},\"body_parts\":[\"upper_legs\",\"glutes\",\"none\",\"none\",\"none\"],\"equipment\":[\"body\",\"none\"]},{\"id\":\"d_000000000903\",\"name\":\"Barbell Hang Snatch Below the Knees\",\"input_format\":\"weight_and_reps\",\"description\":\"Steps :\\r\\n\\r\\n1.) Start by standing in front of a barbell with your feet shoulder width apart and gripping the bar with a double overhand shoulder width grip.\\r\\n\\r\\n2.) Bring the bar to about lower knee level, keeping your back straight, then extend through your hips and knees forcefully driving the weight upward and shrugging your shoulders to your ears at the same time.\\r\\n\\r\\n3.) Moving your feet into the receiving position, pull yourself below the bar as you elevate it overhead making sure that you receive the bar as low as possible and extend your arms up fully over your body.\\r\\n\\r\\n4.) Make sure that you have a balanced standing position and hold for a count, then slowly and under control lower the bar back to the ground.\\r\\n\\r\\n5.) Repeat for as many reps and sets as desired.\",\"type\":\"olympic\",\"difficulty\":\"advanced\",\"popularity\":\"11\",\"media\":{\"image_urls\":[\"https://www.jefit.com/images/exercises/960_590/3612.jpg\",\"https://www.jefit.com/images/exercises/960_590/3613.jpg\",\"https://www.jefit.com/images/exercises/960_590/3614.jpg\",\"https://www.jefit.com/images/exercises/960_590/3615.jpg\"]},\"body_parts\":[\"upper_legs\",\"back\",\"shoulders\",\"none\",\"none\"],\"equipment\":[\"barbell\",\"none\"]},{\"id\":\"d_000000000918\",\"name\":\"Barbell Power Jerk\",\"input_format\":\"weight_and_reps\",\"description\":\"Steps :\\r\\n\\r\\n1.) Start off with a weighted barbell racked on your front shoulders, in a front squat position, with your knees slightly bent and dipping your body a bit so that your feet are directly under your hips.\\r\\n\\r\\n2.) Push up through your heels, creating as much force as possible, and as your feet leave the floor place them in a receiving position as quickly as possible.\\r\\n\\r\\n3.) Elevate the bar up and over your head, keeping a wide stance and your legs still slightly bent to absorb the shifting of the weight.\\r\\n\\r\\n4.) Lock your arms overhead with the barbell in place and stand in an upright position.\\r\\n\\r\\n5.) Hold this position for a count then return back to the start, slowly lowering the weight down in a controlled motion.\\r\\n\\r\\n6.) Repeat for as many reps and sets as desired.\",\"type\":\"olympic\",\"difficulty\":\"advanced\",\"popularity\":\"48\",\"media\":{\"image_urls\":[\"https://www.jefit.com/images/exercises/960_590/3672.jpg\",\"https://www.jefit.com/images/exercises/960_590/3673.jpg\",\"https://www.jefit.com/images/exercises/960_590/3674.jpg\",\"https://www.jefit.com/images/exercises/960_590/3675.jpg\"]},\"body_parts\":[\"upper_legs\",\"shoulders\",\"triceps\",\"none\",\"none\"],\"equipment\":[\"barbell\",\"none\"]},{\"id\":\"d_000000000133\",\"name\":\"Barbell Step-Up\",\"input_format\":\"weight_and_reps\",\"description\":\"The barbell step up exercise helps build coordination as well as muscle and leg strength.\\r\\n\\r\\nSteps : \\r\\n\\r\\n1.) Start by placing a bench, box or step in front of you and grabbing a barbell with a wide grip and placing it across your shoulders.\\r\\n\\r\\n2.) With your left leg, step up onto the bench and follow through with your right leg.\\r\\n\\r\\n3.) Step back down with your left leg and then your right leg.\\r\\n\\r\\n4.) Repeat for as many reps and sets as desired.\\r\\n\\r\\nTips :\\r\\n\\r\\n1.) Use a weight that is manageable and that allows you to get used to the motion of this exercise.\",\"type\":\"strength\",\"difficulty\":\"intermediate\",\"popularity\":\"822\",\"media\":{\"image_urls\":[\"https://www.jefit.com/images/exercises/960_590/532.jpg\",\"https://www.jefit.com/images/exercises/960_590/533.jpg\",\"https://www.jefit.com/images/exercises/960_590/534.jpg\",\"https://www.jefit.com/images/exercises/960_590/535.jpg\"]},\"body_parts\":[\"upper_legs\",\"lower_legs\",\"glutes\",\"hamstrings\",\"calves\"],\"equipment\":[\"barbell\",\"none\"]},{\"id\":\"d_000000001309\",\"name\":\"Machine Leg Press (Wide Stance)\",\"input_format\":\"weight_and_reps\",\"description\":\"Steps :\\r\\n\\r\\n1.) Start by setting up the amount of weight that you would like to perform on a Leg Press Machine.\\r\\n\\r\\n2.) Sit down on the machine and place your legs on the rest with a wide stance and back flat on the padding behind you.\\r\\n\\r\\n3.) Release the weight off of the rack and bring it down, feeling a stretch in your quads and hamstrings until you make a 90-degree angle with your legs or as far as you can go down.\\r\\n\\r\\n4.) Hold for a count then return back to the starting position.\\r\\n\\r\\n5.) Repeat for as many reps and sets as desired.\",\"type\":\"strength\",\"difficulty\":\"beginner\",\"popularity\":\"12138\",\"media\":{\"image_urls\":[\"https://www.jefit.com/images/exercises/960_590/5236.jpg\",\"https://www.jefit.com/images/exercises/960_590/5237.jpg\"]},\"body_parts\":[\"upper_legs\",\"none\",\"none\",\"none\",\"none\"],\"equipment\":[\"machine_strength\",\"none\"]}],\"title\":\"Alternative Upper Legs Exercises\"}]}]\n"])</script><script>self.__next_f.push([1,"43:T57a,"])</script><script>self.__next_f.push([1,"The trap bar squat is an effective exercise for building lower body strength and muscle mass, and it can be a good alternative for individuals who have difficulty performing traditional back squats due to mobility restrictions or discomfort.\r\n\r\nPosition the trap bar on the ground in an open area with the handles parallel to each other. Step into the center of the trap bar so that it's aligned with your feet. Stand with your feet hip-width apart or slightly wider, toes pointed slightly outward. Bend at the hips and knees to grasp the handles of the trap bar with a neutral grip (palms facing each other). Ensure your grip is firm and secure on the handles.\r\n\r\nEngage your core muscles by drawing your navel in towards your spine. Keep your chest up and your shoulders back to maintain proper posture throughout the movement. Initiate the squat movement by bending at your hips and knees simultaneously, as if you were sitting back into a chair.\r\nLower your body down until your thighs are parallel to the ground, or as low as you can comfortably go while maintaining proper form.\r\n\r\nKeep your knees tracking in line with your toes and avoid allowing them to collapse inward. Press through your heels and drive your hips forward as you straighten your legs and return to the starting position. Keep your chest up and your back straight throughout the movement to maintain a neutral spine alignment."])</script><script>self.__next_f.push([1,"44:T7a5,"])</script><script>self.__next_f.push([1,"The dumbbell wall squat hold is a variation of the traditional wall squat that adds resistance to the exercise by holding dumbbells. It primarily targets the muscles of the lower body, including the quadriceps, glutes, and hamstrings, while also engaging the core muscles for stability.\r\n\r\nStand with your back against a wall and your feet positioned slightly wider than shoulder-width apart. Hold a dumbbell in each hand, with your arms hanging down by your sides and your palms facing inward. Keep your feet planted firmly on the ground throughout the exercise.\r\n\r\nSlowly slide your back down the wall, bending your knees and lowering your body into a squat position. Keep your back flat against the wall and your chest lifted. Aim to lower yourself until your thighs are parallel to the ground, or as close to parallel as you can comfortably go.\r\n\r\nOnce you reach the bottom of the squat position, hold this position while keeping tension in your muscles. Ensure your knees are aligned with your toes and not collapsing inward. Maintain a neutral spine and avoid rounding your lower back.\r\n\r\nEngage your core muscles by pulling your belly button towards your spine. Squeeze your glutes and quadriceps to maintain stability and control. Hold the squat position for a predetermined amount of time, such as 20-30 seconds, or longer if you're more advanced. Focus on breathing steadily throughout the hold, inhaling through your nose and exhaling through your mouth.\r\n\r\nAfter holding the squat position for the desired duration, slowly push through your heels and straighten your legs to return to the starting position. Keep your back pressed against the wall as you rise up.\r\n\r\nPerform the dumbbell wall squat hold for the desired number of repetitions or hold times, depending on your fitness level and goals. You can gradually increase the duration of the hold or the weight of the dumbbells as you become stronger and more comfortable with the exercise."])</script><script>self.__next_f.push([1,"45:T522,The barbell landmine squat targets multiple muscle groups, including the quadriceps, hamstrings, glutes, and core, making it an effective lower body and core strengthening exercise.\r\n\r\nPlace one end of the barbell into the landmine attachment or secure it in a corner. Load weight plates onto the other end of the barbell according to your strength and fitness level.\r\n\r\nStand facing the landmine with your feet shoulder-width apart or slightly wider. The barbell should be positioned at your side, with your chosen side to hold the barbell.\r\n\r\nHold the barbell with one hand, palm facing inward, at about chest height. Your arm should be bent at the elbow, with your forearm parallel to the floor. This hand will serve to stabilize the barbell during the exercise.\r\n\r\nBrace your core and keep your chest up as you initiate the squat by bending your hips and knees simultaneously.\r\nLower your body down, keeping your back straight and your weight on your heels.\r\nLower yourself until your thighs are approximately parallel to the ground or as low as your flexibility allows while maintaining good form.\r\n\r\nPress through your heels and drive your hips forward as you stand back up, straightening your legs and returning to the starting position. Keep your core engaged throughout the movement to maintain stability.46:T6be,"])</script><script>self.__next_f.push([1,"The weight plate wall sit is a variation of the traditional wall sit exercise that adds resistance to increase the challenge for your lower body muscles, particularly the quadriceps, hamstrings, and glutes.\r\n\r\nStand with your back pressed firmly against the wall. Walk your feet out and slide your back down the wall until your knees are bent at a 90-degree angle, or as close to 90 degrees as possible. Your feet should be positioned slightly wider than shoulder-width apart, and your knees should be aligned with your ankles.\r\n\r\nWith your hands gripping the weight plate in front of your chest, keep your elbows bent and close to your body.\r\nEnsure that the weight plate is held securely and does not slip during the exercise. Brace your core muscles to stabilize your spine and maintain proper posture throughout the exercise.\r\n\r\nHold the wall sit position with your knees bent at a 90-degree angle and your back pressed against the wall.\r\nKeep your chest lifted, shoulders back, and gaze straight ahead.\r\nEnsure that your weight is distributed evenly through your feet, with the majority of the pressure on your heels.\r\n\r\nHold the wall sit position for a predetermined amount of time, such as 20-30 seconds, or longer if you're more advanced. Focus on breathing steadily throughout the hold, inhaling through your nose and exhaling through your mouth.\r\n\r\nAfter completing the hold, slowly push through your heels and straighten your legs to return to the standing position against the wall. Keep your back pressed against the wall as you rise up. Take a short rest period before repeating the exercise for additional sets or hold times. Aim to perform 2-3 sets of wall sits, holding each position for the desired duration."])</script><script>self.__next_f.push([1,"47:T691,"])</script><script>self.__next_f.push([1,"Performing front-to-back leg swings is an excellent dynamic warm-up exercise that helps to increase flexibility, mobility, and blood flow to the lower body.\r\n\r\nStand tall with your feet hip-width apart and your arms relaxed by your sides. Engage your core muscles by gently pulling your belly button towards your spine to stabilize your torso. If needed, you can use a wall or a sturdy object for support to maintain your balance during the exercise.\r\n\r\nBegin by swinging one leg forward in a controlled motion. Keep your knee straight but not locked. Swing your leg as high as comfortable, aiming for a gentle stretch in the hamstrings. After swinging your leg forward, smoothly swing it backward in the opposite direction. Again, keep your knee straight but not locked, and aim for a gentle stretch in the quadriceps by bending the knee, trying to kick your buttock with your heel.\r\n\r\nFocus on maintaining control throughout the movement. Avoid swinging your leg too forcefully or using momentum to lift it. The motion should be controlled and deliberate. After completing the desired number of repetitions on one leg, switch to the other leg and repeat the exercise.\r\n\r\nWhile swinging your legs, keep your upper body stable and avoid leaning excessively forward or backward. Your torso should remain upright throughout the exercise. Coordinate your breathing with the movement. Inhale as you swing your leg forward, and exhale as you swing it backward.\r\n\r\nGradually Increase Range of Motion: As you warm up, gradually increase the range of motion of your leg swings. Try to swing your leg higher with each repetition, but only go as far as you can comfortably without straining."])</script><script>self.__next_f.push([1,"48:T6f4,"])</script><script>self.__next_f.push([1,"The barbell squat is a fundamental exercise for building lower body strength, targeting the quadriceps, hamstrings, glutes, and core. Here’s how to perform it correctly:\r\n\r\nSetup:\r\n\r\nLoad the barbell with the desired weight and position it on a squat rack at about shoulder height. Stand under the barbell with your feet shoulder-width apart.\r\n\r\nPositioning the Barbell:\r\n\r\nPosition the barbell across your upper back (trapezius muscles), not your neck. You can use a high-bar position (resting on your traps) or a low-bar position (resting across the rear deltoids, just below the traps). Grip the barbell with your hands slightly wider than shoulder-width apart. Lift your elbows slightly to create a stable shelf with your upper back muscles for the bar to rest on.\r\n\r\nUnracking the Barbell:\r\n\r\nStand up to lift the barbell off the rack, taking a step or two back to clear the rack. Ensure your feet are shoulder-width apart with toes slightly pointed out.\r\n\r\nStarting Position:\r\n\r\nKeep your chest up, back straight, and core engaged. Look forward or slightly up, maintaining a neutral head position. Ensure your weight is evenly distributed across your feet.\r\n\r\nDescending into the Squat:\r\n\r\nInhale deeply to brace your core. Push your hips back and bend your knees to lower your body into the squat.\r\nKeep your chest up and your back straight throughout the movement. Lower yourself until your thighs are at least parallel to the ground. If you have the flexibility, you can go lower, but avoid rounding your lower back.\r\n\r\nAscending from the Squat:\r\n\r\nExhale and push through your heels to stand back up. Extend your knees and hips simultaneously, keeping your chest up and back straight. Fully extend your legs at the top of the movement but avoid locking out your knees."])</script><script>self.__next_f.push([1,"49:T539,This exercise can be performed using a kettlebell or depending on what equipment you have either a dumbbell or weight plate.\r\n\r\nStand next to the kettlebell with your feet shoulder-width apart. Hinge at your hips and bend your knees slightly to reach down and grab the kettlebell handle with one hand. Keep your back straight, chest up, and core engaged.\r\n\r\nWith a firm grip on the handle, lift the kettlebell off the ground. Brace your core to stabilize your spine as you lift.\r\nOnce the kettlebell is off the ground, stand up tall with your shoulders back and down. Keep the kettlebell close to your body, avoiding any leaning to the side.\r\n\r\nKeep your shoulders square and level throughout the exercise. Avoid leaning away from the kettlebell side or allowing your torso to tilt.\r\n\r\nBegin to walk slowly and steadily while holding the kettlebell in one hand. Take short, controlled steps, ensuring that your core remains engaged and your posture stays upright. Walk for a predetermined distance or time, depending on your fitness level and goals.\r\n\r\nAfter completing the designated distance or time, carefully lower the kettlebell back to the ground. Take a moment to rest and reset your posture. Repeat the exercise on the opposite side by picking up the kettlebell with your other hand and performing the carry in the same manner.\r\n"])</script><script>self.__next_f.push([1,"33:[\"$\",\"div\",null,{\"className\":\"lg:hidden w-full text-center mt-10\",\"children\":[\"$\",\"$L40\",null,{\"exercises\":[{\"id\":\"d_000000000942\",\"name\":\"Barbell Snatch from Blocks\",\"input_format\":\"weight_and_reps\",\"description\":\"Steps :\\r\\n\\r\\n1.) Begin by standing in front of a barbell rested upon boxes, with your feet shoulder width apart and gripping the bar with a double overhand shoulder width grip.\\r\\n\\r\\n2.) Bring the bar to about lower knee level, keeping your back straight, then extend through your hips and knees forcefully driving the weight upward and shrugging your shoulders to your ears at the same time.\\r\\n\\r\\n3.) Moving your feet into the receiving position, pull yourself below the bar as you elevate it overhead making sure that you receive the bar as low as possible and extend your arms up fully over your body.\\r\\n\\r\\n4.) Make sure that you have a balanced standing position and hold for a count, then slowly and under control lower the bar back to the ground.\\r\\n\\r\\n5.) Repeat for as many reps and sets as desired.\",\"type\":\"olympic\",\"difficulty\":\"advanced\",\"popularity\":\"7\",\"media\":{\"image_urls\":[\"https://www.jefit.com/images/exercises/960_590/3768.jpg\",\"https://www.jefit.com/images/exercises/960_590/3769.jpg\",\"https://www.jefit.com/images/exercises/960_590/3770.jpg\",\"https://www.jefit.com/images/exercises/960_590/3771.jpg\"]},\"body_parts\":[\"upper_legs\",\"back\",\"shoulders\",\"none\",\"none\"],\"equipment\":[\"barbell\",\"none\"]},{\"id\":\"d_000000000750\",\"name\":\"Prisoner Squat\",\"input_format\":\"reps\",\"description\":\"Steps :\\r\\n\\r\\n1.) Start by standing up straight with wide feet and your hands behind your head.\\r\\n\\r\\n2.) Slowly lower your body in a controlled squat, extending your hips and knees feeling a stretch in your thighs and glutes.\\r\\n\\r\\n3.) Return back to the starting position and repeat for as many reps and sets as desired.\",\"type\":\"strength\",\"difficulty\":\"beginner\",\"popularity\":\"3851\",\"media\":{\"image_urls\":[\"https://www.jefit.com/images/exercises/960_590/3000.jpg\",\"https://www.jefit.com/images/exercises/960_590/3001.jpg\",\"https://www.jefit.com/images/exercises/960_590/3002.jpg\",\"https://www.jefit.com/images/exercises/960_590/3003.jpg\"]},\"body_parts\":[\"upper_legs\",\"none\",\"none\",\"none\",\"none\"],\"equipment\":[\"body\",\"none\"]},{\"id\":\"d_000000001206\",\"name\":\"Single-Leg Squat\",\"input_format\":\"weight_and_reps\",\"description\":\"Steps :\\r\\n\\r\\n1.) Start by setting up a horizontal flat bench behind you and placing one of your legs behind you in the middle of the bench as this will be your starting position.\\r\\n\\r\\n2.) Cross your arms in front of you and slowly lower your body down towards the floor, bending with your front leg until your knee is parallel with the floor and hold for a count.\\r\\n\\r\\n3.) Return back to the starting position.\\r\\n\\r\\n4.) Repeat for as many reps and sets as desired.\",\"type\":\"strength\",\"difficulty\":\"beginner\",\"popularity\":\"652\",\"media\":{\"image_urls\":[\"https://www.jefit.com/images/exercises/960_590/4824.jpg\",\"https://www.jefit.com/images/exercises/960_590/4825.jpg\",\"https://www.jefit.com/images/exercises/960_590/4826.jpg\",\"https://www.jefit.com/images/exercises/960_590/4827.jpg\"]},\"body_parts\":[\"upper_legs\",\"glutes\",\"lower_legs\",\"none\",\"none\"],\"equipment\":[\"body\",\"none\"]},{\"id\":\"d_000000001220\",\"name\":\"Bodyweight Side Lunge\",\"input_format\":\"reps\",\"description\":\"Steps :\\r\\n\\r\\n1.) Start by standing up straight with a slight bend in your knees.\\r\\n\\r\\n2.) Step out to your side with your left leg and squat down through your hips.\\r\\n\\r\\n3.) Lower yourself towards the floor so that your front leg is parallel with the floor and hold for a count.\\r\\n\\r\\n4.) Return back to the starting position.\\r\\n\\r\\n5.) Repeat for as many reps and sets as desired.\",\"type\":\"strength\",\"difficulty\":\"beginner\",\"popularity\":\"2985\",\"media\":{\"image_urls\":[\"https://www.jefit.com/images/exercises/960_590/4880.jpg\",\"https://www.jefit.com/images/exercises/960_590/4881.jpg\",\"https://www.jefit.com/images/exercises/960_590/4882.jpg\",\"https://www.jefit.com/images/exercises/960_590/4883.jpg\"]},\"body_parts\":[\"upper_legs\",\"glutes\",\"none\",\"none\",\"none\"],\"equipment\":[\"body\",\"none\"]},{\"id\":\"d_000000000128\",\"name\":\"Barbell Lunge\",\"input_format\":\"weight_and_reps\",\"description\":\"The barbell lunge exercise is a classic leg and lower body exercise that helps strengthen leg muscles and build overall strength.\\r\\n\\r\\nSteps : \\r\\n\\r\\n1.) Start off by placing a weighted barbell across your upper back, using a slightly wider shoulder-width grip, keeping your feet about 8 inches apart and toes facing forward.\\r\\n\\r\\n2.) Once in position, take a step forward (about 2 to 3 feet), making sure that you keep your abs tight and your upper body straight, and lower your back knee towards the floor as if you were kneeling.\\r\\n\\r\\n3.) As you continue down towards the floor, keep your other knee bent at a 90 degree angle while making sure that your back knee does not touch the ground.\\r\\n\\r\\n4.) Once in the final position and you feel a stretch in your muscles, hold for a count then return back to the starting position.\\r\\n\\r\\nTips :\\r\\n\\r\\n1.) Do not put the pressure of your body on your knee during this exercise.\\r\\n\\r\\n2.) The knee you are leaning forward on should not move beyond the toe of this foot.\",\"type\":\"strength\",\"difficulty\":\"intermediate\",\"popularity\":\"8526\",\"media\":{\"image_urls\":[\"https://www.jefit.com/images/exercises/960_590/512.jpg\",\"https://www.jefit.com/images/exercises/960_590/513.jpg\",\"https://www.jefit.com/images/exercises/960_590/514.jpg\",\"https://www.jefit.com/images/exercises/960_590/515.jpg\"]},\"body_parts\":[\"upper_legs\",\"lower_legs\",\"glutes\",\"hamstrings\",\"quads\"],\"equipment\":[\"barbell\",\"none\"]},{\"id\":\"d_000000001399\",\"name\":\"Trap Bar Squat\",\"input_format\":\"weight_and_reps\",\"description\":\"$43\",\"type\":\"strength\",\"difficulty\":\"intermediate\",\"popularity\":\"658\",\"media\":{\"image_urls\":[\"https://www.jefit.com/images/exercises/960_590/5596.jpg\",\"https://www.jefit.com/images/exercises/960_590/5597.jpg\",\"https://www.jefit.com/images/exercises/960_590/5598.jpg\",\"https://www.jefit.com/images/exercises/960_590/5599.jpg\"]},\"body_parts\":[\"upper_legs\",\"glutes\",\"traps\",\"back\",\"none\"],\"equipment\":[\"hex_bar\",\"none\"]},{\"id\":\"d_000000001256\",\"name\":\"Machine Single-Leg Extension \",\"input_format\":\"weight_and_reps\",\"description\":\"Steps :\\r\\n\\r\\n1.) Start by sitting on a leg extension machine, with both legs rested underneath the padding and your back flat on the rest behind you.\\r\\n\\r\\n2.) Slowly, while keeping your upper body still, elevate the padding up with just one of your legs, keeping the other still in the starting position.\\r\\n\\r\\n3.) Squeeze with your quads and hamstrings on the way up, going up as far as possible and hold for a count.\\r\\n\\r\\n4.) Return back to the starting position.\\r\\n\\r\\n5.) Repeat for as many reps and sets as desired.\",\"type\":\"strength\",\"difficulty\":\"beginner\",\"popularity\":\"13111\",\"media\":{\"image_urls\":[\"https://www.jefit.com/images/exercises/960_590/5024.jpg\",\"https://www.jefit.com/images/exercises/960_590/5025.jpg\"]},\"body_parts\":[\"upper_legs\",\"none\",\"none\",\"none\",\"none\"],\"equipment\":[\"machine_strength\",\"none\"]},{\"id\":\"d_000000000133\",\"name\":\"Barbell Step-Up\",\"input_format\":\"weight_and_reps\",\"description\":\"The barbell step up exercise helps build coordination as well as muscle and leg strength.\\r\\n\\r\\nSteps : \\r\\n\\r\\n1.) Start by placing a bench, box or step in front of you and grabbing a barbell with a wide grip and placing it across your shoulders.\\r\\n\\r\\n2.) With your left leg, step up onto the bench and follow through with your right leg.\\r\\n\\r\\n3.) Step back down with your left leg and then your right leg.\\r\\n\\r\\n4.) Repeat for as many reps and sets as desired.\\r\\n\\r\\nTips :\\r\\n\\r\\n1.) Use a weight that is manageable and that allows you to get used to the motion of this exercise.\",\"type\":\"strength\",\"difficulty\":\"intermediate\",\"popularity\":\"822\",\"media\":{\"image_urls\":[\"https://www.jefit.com/images/exercises/960_590/532.jpg\",\"https://www.jefit.com/images/exercises/960_590/533.jpg\",\"https://www.jefit.com/images/exercises/960_590/534.jpg\",\"https://www.jefit.com/images/exercises/960_590/535.jpg\"]},\"body_parts\":[\"upper_legs\",\"lower_legs\",\"glutes\",\"hamstrings\",\"calves\"],\"equipment\":[\"barbell\",\"none\"]},{\"id\":\"d_000000000908\",\"name\":\"Kneeling Hip Flexor\",\"input_format\":\"reps_and_duration\",\"description\":\"Steps :\\r\\n\\r\\n1.) Start by kneeling on a mat bringing one of your knees up so that the bottom of your foot is rested upon the floor the other leg is extended out behind you.\\r\\n\\r\\n2.) Slowly shift your weight forward onto the bent leg until you feel a stretch in your quads.\\r\\n\\r\\n3.) Hold for 15 to 30 seconds and then return to the starting position.\\r\\n\\r\\n4.) Repeat for as many reps, sets and however long you desire.\",\"type\":\"stretching\",\"difficulty\":\"beginner\",\"popularity\":\"618\",\"media\":{\"image_urls\":[\"https://www.jefit.com/images/exercises/960_590/3632.jpg\",\"https://www.jefit.com/images/exercises/960_590/3633.jpg\",\"https://www.jefit.com/images/exercises/960_590/3634.jpg\",\"https://www.jefit.com/images/exercises/960_590/3635.jpg\"]},\"body_parts\":[\"upper_legs\",\"none\",\"none\",\"none\",\"none\"],\"equipment\":[\"body\",\"none\"]},{\"id\":\"d_000000001382\",\"name\":\"Dumbbell Wall Squat Hold\",\"input_format\":\"duration\",\"description\":\"$44\",\"type\":\"strength\",\"difficulty\":\"intermediate\",\"popularity\":\"540\",\"media\":{\"image_urls\":[\"https://www.jefit.com/images/exercises/960_590/5528.jpg\",\"https://www.jefit.com/images/exercises/960_590/5529.jpg\",\"https://www.jefit.com/images/exercises/960_590/5530.jpg\",\"https://www.jefit.com/images/exercises/960_590/5531.jpg\"]},\"body_parts\":[\"upper_legs\",\"back\",\"abs\",\"traps\",\"forearms\"],\"equipment\":[\"dumbbell\",\"none\"]},{\"id\":\"d_000000000132\",\"name\":\"Machine Leg Press\",\"input_format\":\"weight_and_reps\",\"description\":\"The leg press exercise is a variation of leg press workouts which targets the external muscles of the legs by placing your feet closely together.\\r\\n\\r\\nSteps : \\r\\n\\r\\n1.) Start off sitting on a leg press machine with your feet on the crosspiece about 6 inces apart with your toes pointed outward.\\r\\n\\r\\n2.) Once in position, grab the handles on the sides of the machine, release the locks, slowly bend down at your knees and bring the weight as far as possible towards your chest.\\r\\n\\r\\n3.) Hold for a count and then return back to the starting position.\\r\\n\\r\\n4.) Repeat for as many reps and sets as desired.\\r\\n\\r\\nTips : \\r\\n\\r\\n1.) Do not lock your knees at the top as this can result in injury.\",\"type\":\"strength\",\"difficulty\":\"beginner\",\"popularity\":\"109171\",\"media\":{\"image_urls\":[\"https://www.jefit.com/images/exercises/960_590/528.jpg\",\"https://www.jefit.com/images/exercises/960_590/529.jpg\"]},\"body_parts\":[\"upper_legs\",\"lower_legs\",\"glutes\",\"hamstrings\",\"quads\"],\"equipment\":[\"machine_strength\",\"none\"]},{\"id\":\"d_000000001199\",\"name\":\"Hack Squat (Reverse Position)\",\"input_format\":\"weight_and_reps\",\"description\":\"Steps :\\r\\n\\r\\n1.) Start by setting up the hack squat machine with the amount of weight that you would like to perform for this exercise and then place yourself with your chest flat on the pad and shoulders up against the shoulder rests.\\r\\n\\r\\n2.) Push up with your body to remove the weights up off of the stacks and place your arms on the side handles as this will be your starting position.\\r\\n\\r\\n3.) Slowly lower the weight down until your thighs create right angles with your calves and hold for a count.\\r\\n\\r\\n4.) Return back to the starting position.\\r\\n\\r\\n5.) Repeat for as many reps and sets as desired.\",\"type\":\"strength\",\"difficulty\":\"intermediate\",\"popularity\":\"2866\",\"media\":{\"image_urls\":[\"https://www.jefit.com/images/exercises/960_590/4796.jpg\",\"https://www.jefit.com/images/exercises/960_590/4797.jpg\",\"https://www.jefit.com/images/exercises/960_590/4798.jpg\",\"https://www.jefit.com/images/exercises/960_590/4799.jpg\"]},\"body_parts\":[\"upper_legs\",\"glutes\",\"lower_legs\",\"none\",\"none\"],\"equipment\":[\"machine_strength\",\"none\"]},{\"id\":\"d_000000001225\",\"name\":\"Bodyweight Step-Up\",\"input_format\":\"reps\",\"description\":\"Steps :\\r\\n\\r\\n1.) Start by setting up a horizontal bench in front of you, standing up straight with your feet in a shoulder width position and arms at your sides.\\r\\n\\r\\n2.) Lift your left foot and step up onto the platform.\\r\\n\\r\\n3.) Then once your foot is firmly on the platform, raise up your right foot and follow up onto the platform so that you are standing up on the platform.\\r\\n\\r\\n4.) Return back to the starting position.\\r\\n\\r\\n5.) Repeat for as many reps and sets as desired.\",\"type\":\"strength\",\"difficulty\":\"beginner\",\"popularity\":\"1742\",\"media\":{\"image_urls\":[\"https://www.jefit.com/images/exercises/960_590/4900.jpg\",\"https://www.jefit.com/images/exercises/960_590/4901.jpg\",\"https://www.jefit.com/images/exercises/960_590/4902.jpg\",\"https://www.jefit.com/images/exercises/960_590/4903.jpg\"]},\"body_parts\":[\"upper_legs\",\"glutes\",\"lower_legs\",\"none\",\"none\"],\"equipment\":[\"bench\",\"none\"]},{\"id\":\"d_000000001348\",\"name\":\"Barbell Landmine Squat\",\"input_format\":\"weight_and_reps\",\"description\":\"$45\",\"type\":\"strength\",\"difficulty\":\"beginner\",\"popularity\":\"833\",\"media\":{\"image_urls\":[\"https://www.jefit.com/images/exercises/960_590/5392.jpg\",\"https://www.jefit.com/images/exercises/960_590/5393.jpg\",\"https://www.jefit.com/images/exercises/960_590/5394.jpg\",\"https://www.jefit.com/images/exercises/960_590/5395.jpg\"]},\"body_parts\":[\"upper_legs\",\"glutes\",\"abs\",\"back\",\"shoulders\"],\"equipment\":[\"barbell\",\"none\"]},{\"id\":\"d_000000001384\",\"name\":\"Weight Plate Wall Sit\",\"input_format\":\"duration\",\"description\":\"$46\",\"type\":\"strength\",\"difficulty\":\"intermediate\",\"popularity\":\"1408\",\"media\":{\"image_urls\":[\"https://www.jefit.com/images/exercises/960_590/5536.jpg\",\"https://www.jefit.com/images/exercises/960_590/5537.jpg\",\"https://www.jefit.com/images/exercises/960_590/5538.jpg\",\"https://www.jefit.com/images/exercises/960_590/5539.jpg\"]},\"body_parts\":[\"upper_legs\",\"lower_chest\",\"glutes\",\"none\",\"none\"],\"equipment\":[\"weight_plate\",\"none\"]},{\"id\":\"d_000000000480\",\"name\":\"Kettlebell Dead Clean\",\"input_format\":\"weight_and_reps\",\"description\":\"Steps : \\r\\n\\r\\n1.) To begin this exercise; start off by taking a kettlebell in one arm and bending over by your knees and pushing your glutes out with the kettlebell resting on the floor between your legs.\\r\\n\\r\\n2.) From the bent position, clean press the kettlebell to your shoulder and hold for a few seconds.\\r\\n\\r\\n3.) Return back to the starting position.\\r\\n\\r\\n4.) Repeat this exercise for as many repetitions as needed\",\"type\":\"strength\",\"difficulty\":\"intermediate\",\"popularity\":\"324\",\"media\":{\"image_urls\":[\"https://www.jefit.com/images/exercises/960_590/1920.jpg\",\"https://www.jefit.com/images/exercises/960_590/1921.jpg\",\"https://www.jefit.com/images/exercises/960_590/1922.jpg\",\"https://www.jefit.com/images/exercises/960_590/1923.jpg\"]},\"body_parts\":[\"upper_legs\",\"back\",\"glutes\",\"hamstrings\",\"quads\"],\"equipment\":[\"kettlebell\",\"none\"]},{\"id\":\"d_000000001210\",\"name\":\"Dumbbell Jump Squat\",\"input_format\":\"weight_and_reps\",\"description\":\"Steps :\\r\\n\\r\\n1.) Start by standing up straight, feet shoulder width apart and holding a dumbbell in each hand at your sides with a neutral grip.\\r\\n\\r\\n2.) Slightly bend with your knees, keeping your back straight and chest pushed out.\\r\\n\\r\\n3.) Squat down until your thighs are parallel with the floor, then explode upward driving the balls of your feet into the floor and jumping as high as possible then returning back to the squatting position.\\r\\n\\r\\n4.) Repeat for as many reps and sets as desired.\",\"type\":\"strength\",\"difficulty\":\"intermediate\",\"popularity\":\"684\",\"media\":{\"image_urls\":[\"https://www.jefit.com/images/exercises/960_590/4840.jpg\",\"https://www.jefit.com/images/exercises/960_590/4841.jpg\",\"https://www.jefit.com/images/exercises/960_590/4842.jpg\",\"https://www.jefit.com/images/exercises/960_590/4843.jpg\"]},\"body_parts\":[\"upper_legs\",\"glutes\",\"lower_legs\",\"none\",\"none\"],\"equipment\":[\"dumbbell\",\"none\"]},{\"id\":\"d_000000001419\",\"name\":\"Front to Back Leg Swings\",\"input_format\":\"reps_and_duration\",\"description\":\"$47\",\"type\":\"dynamic\",\"difficulty\":\"beginner\",\"popularity\":\"1379\",\"media\":{\"image_urls\":[\"https://www.jefit.com/images/exercises/960_590/5676.jpg\",\"https://www.jefit.com/images/exercises/960_590/5677.jpg\",\"https://www.jefit.com/images/exercises/960_590/5678.jpg\",\"https://www.jefit.com/images/exercises/960_590/5679.jpg\"]},\"body_parts\":[\"upper_legs\",\"glutes\",\"none\",\"none\",\"none\"],\"equipment\":[\"body\",\"none\"]},{\"id\":\"d_000000000951\",\"name\":\"Long Jump\",\"input_format\":\"reps\",\"description\":\"Steps :\\r\\n\\r\\n1.) Begin by standing up straight with enough space and distance around you to perform this exercise.\\r\\n\\r\\n2.) Slowly bend your knees, extending your body forward, then quickly and forcefully use a big arm swing to create momentum and jump forward with your body as far as you can.\\r\\n\\r\\n3.) While in mid air shift your legs forward so that you land with your feet in front of you.\\r\\n\\r\\n4.) Measure your distance and repeat for as many reps and sets as desired.\",\"type\":\"strength\",\"difficulty\":\"beginner\",\"popularity\":\"331\",\"media\":{\"image_urls\":[\"https://www.jefit.com/images/exercises/960_590/3804.jpg\",\"https://www.jefit.com/images/exercises/960_590/3805.jpg\",\"https://www.jefit.com/images/exercises/960_590/3806.jpg\",\"https://www.jefit.com/images/exercises/960_590/3807.jpg\"]},\"body_parts\":[\"upper_legs\",\"glutes\",\"lower_legs\",\"none\",\"none\"],\"equipment\":[\"body\",\"none\"]},{\"id\":\"d_000000001198\",\"name\":\"Dumbbell Hamstring Curl\",\"input_format\":\"weight_and_reps\",\"description\":\"Steps :\\r\\n\\r\\n1.) Start by setting up an elevated flat bench on either a block or step and making sure that your resting point is secure.\\r\\n\\r\\n2.) Lie face down on the bench, placing a dumbbell at the lower end of the bench so that you will be able to grab it in between your feet, and that your knees are at the edge of the bench.\\r\\n\\r\\n3.) Pick the dumbbell up off of the floor with your feet, keeping your legs fully extended, and slowly curl the dumbbell up towards your buttocks by bending your knees.\\r\\n\\r\\n4.) Hold for a count when you feel a stretch in your hamstrings then return back to the starting position.\\r\\n\\r\\n5.) Repeat for as many reps and sets as desired.\",\"type\":\"strength\",\"difficulty\":\"intermediate\",\"popularity\":\"3768\",\"media\":{\"image_urls\":[\"https://www.jefit.com/images/exercises/960_590/4792.jpg\",\"https://www.jefit.com/images/exercises/960_590/4793.jpg\",\"https://www.jefit.com/images/exercises/960_590/4794.jpg\",\"https://www.jefit.com/images/exercises/960_590/4795.jpg\"]},\"body_parts\":[\"upper_legs\",\"none\",\"none\",\"none\",\"none\"],\"equipment\":[\"dumbbell\",\"none\"]},{\"id\":\"d_000000000280\",\"name\":\"Dumbbell Lateral Lunge with Bicep Curl\",\"input_format\":\"weight_and_reps\",\"description\":\"The lateral lunge with a dumbbell bicep curl exercise is an advanced workout that combines a lateral lunge with a bicep curl\\r\\n\\r\\nSteps : \\r\\n\\r\\n1.) Start by grabbing a dumbbell in each hand with your palms facing up and standing up straight with your feet together, your back straight and your abs drawn in.\\r\\n\\r\\n2.) Allow your arms to extend down fully in front of your thighs.\\r\\n\\r\\n3.) While keeping your body straight, take a step sideways and then bend your waist and your knee into a lunge.\\r\\n\\r\\n4.) As you go into the lunge curl your arms up towards your shoulders contracting your biceps, squeezing the muscle.\\r\\n\\r\\n5.) Hold for a count and then return to starting position and switch legs.\\r\\n\\r\\n6.) Repeat for as many reps and sets as desired.\\r\\n\",\"type\":\"strength\",\"difficulty\":\"intermediate\",\"popularity\":\"417\",\"media\":{\"image_urls\":[\"https://www.jefit.com/images/exercises/960_590/1120.jpg\",\"https://www.jefit.com/images/exercises/960_590/1121.jpg\",\"https://www.jefit.com/images/exercises/960_590/1122.jpg\",\"https://www.jefit.com/images/exercises/960_590/1123.jpg\"]},\"body_parts\":[\"upper_legs\",\"biceps\",\"glutes\",\"hamstrings\",\"quads\"],\"equipment\":[\"dumbbell\",\"none\"]},{\"id\":\"d_000000001200\",\"name\":\"Machine Single-Leg Curl\",\"input_format\":\"weight_and_reps\",\"description\":\"Steps :\\r\\n\\r\\n1.) Start by setting up a single leg curl machine with the amount of weight that you would like to perform for this exercise. \\r\\n\\r\\n2.) Lay with your face down on the machine and the padding just above your ankles.\\r\\n\\r\\n3.) Squeeze your hamstring and curl the weight up with one of your legs, until you feel a stretch then hold for a count.\\r\\n\\r\\n4.) Return to the starting position.\\r\\n\\r\\n5.) Repeat for as many reps and sets as desired.\",\"type\":\"strength\",\"difficulty\":\"beginner\",\"popularity\":\"3995\",\"media\":{\"image_urls\":[\"https://www.jefit.com/images/exercises/960_590/4800.jpg\",\"https://www.jefit.com/images/exercises/960_590/4801.jpg\"]},\"body_parts\":[\"upper_legs\",\"none\",\"none\",\"none\",\"none\"],\"equipment\":[\"machine_strength\",\"none\"]},{\"id\":\"d_000000000012\",\"name\":\"Barbell Squat\",\"input_format\":\"weight_and_reps\",\"description\":\"$48\",\"type\":\"strength\",\"difficulty\":\"beginner\",\"popularity\":\"99446\",\"media\":{\"image_urls\":[\"https://www.jefit.com/images/exercises/960_590/48.jpg\",\"https://www.jefit.com/images/exercises/960_590/49.jpg\",\"https://www.jefit.com/images/exercises/960_590/50.jpg\",\"https://www.jefit.com/images/exercises/960_590/51.jpg\"]},\"body_parts\":[\"upper_legs\",\"glutes\",\"hamstrings\",\"abs\",\"lower_back\"],\"equipment\":[\"barbell\",\"none\"]},{\"id\":\"d_000000001380\",\"name\":\"Kettlebell Suitcase Carry\",\"input_format\":\"weight_and_reps\",\"description\":\"$49\",\"type\":\"strength\",\"difficulty\":\"beginner\",\"popularity\":\"1230\",\"media\":{\"image_urls\":[\"https://www.jefit.com/images/exercises/960_590/5520.jpg\",\"https://www.jefit.com/images/exercises/960_590/5521.jpg\",\"https://www.jefit.com/images/exercises/960_590/5522.jpg\",\"https://www.jefit.com/images/exercises/960_590/5523.jpg\"]},\"body_parts\":[\"upper_legs\",\"back\",\"traps\",\"lower_legs\",\"forearms\"],\"equipment\":[\"kettlebell\",\"none\"]},{\"id\":\"d_000000000952\",\"name\":\"Toe Touch Stretch\",\"input_format\":\"reps_and_duration\",\"description\":\"Steps :\\r\\n\\r\\n1.) Start by standing up straight with your feet hip-width apartr and arms by your side.\\r\\n\\r\\n2.) Slowly bend at your waist, keeping a slight bend in your legs straight, and let your body hang down in front of you, hands reaching down towards the ground.\\r\\n\\r\\n3.) Hold onto this position for 15 to 30 seconds then return back to the start.\\r\\n\\r\\n4.) Repeat for as many reps, sets and however long you desire.\",\"type\":\"stretching\",\"difficulty\":\"beginner\",\"popularity\":\"1162\",\"media\":{\"image_urls\":[\"https://www.jefit.com/images/exercises/960_590/3808.jpg\",\"https://www.jefit.com/images/exercises/960_590/3809.jpg\",\"https://www.jefit.com/images/exercises/960_590/3810.jpg\",\"https://www.jefit.com/images/exercises/960_590/3811.jpg\"]},\"body_parts\":[\"upper_legs\",\"lower_legs\",\"none\",\"none\",\"none\"],\"equipment\":[\"body\",\"none\"]}],\"title\":\"Alternative Upper Legs Exercises\"}]}]\n"])</script><script>self.__next_f.push([1,"1b:null\n"])</script><script>self.__next_f.push([1,"1f:[[\"$\",\"title\",\"0\",{\"children\":\"Dumbbell Reverse Lunge - JEFIT\"}],[\"$\",\"meta\",\"1\",{\"name\":\"description\",\"content\":\"Boost your fitness with the Dumbbell Reverse Lunge, targeting the Upper Legs muscles. It uses Dumbbell and is ideal for all levels to strengthen, tone, and improve performance.\"}],[\"$\",\"meta\",\"2\",{\"property\":\"og:title\",\"content\":\"Dumbbell Reverse Lunge - JEFIT\"}],[\"$\",\"meta\",\"3\",{\"property\":\"og:description\",\"content\":\"Boost your fitness with the Dumbbell Reverse Lunge, targeting the Upper Legs muscles. It uses Dumbbell and is ideal for all levels to strengthen, tone, and improve performance.\"}],[\"$\",\"meta\",\"4\",{\"property\":\"og:image\",\"content\":\"https://www.jefit.com/images/exercises/960_590/1892.jpg\"}],[\"$\",\"meta\",\"5\",{\"name\":\"twitter:card\",\"content\":\"summary_large_image\"}],[\"$\",\"meta\",\"6\",{\"name\":\"twitter:title\",\"content\":\"Dumbbell Reverse Lunge - JEFIT\"}],[\"$\",\"meta\",\"7\",{\"name\":\"twitter:description\",\"content\":\"Boost your fitness with the Dumbbell Reverse Lunge, targeting the Upper Legs muscles. It uses Dumbbell and is ideal for all levels to strengthen, tone, and improve performance.\"}],[\"$\",\"meta\",\"8\",{\"name\":\"twitter:image\",\"content\":\"https://www.jefit.com/images/exercises/960_590/1892.jpg\"}],[\"$\",\"link\",\"9\",{\"rel\":\"shortcut icon\",\"href\":\"/icons/favicons/favicon-32x32.png\"}],[\"$\",\"link\",\"10\",{\"rel\":\"icon\",\"href\":\"/icons/favicons/favicon.ico\"}],[\"$\",\"link\",\"11\",{\"rel\":\"apple-touch-icon\",\"href\":\"/icons/favicons/apple-touch-icon.png\"}],[\"$\",\"link\",\"12\",{\"rel\":\"icon\",\"href\":\"/icons/favicons/favicon-16x16.png\",\"type\":\"image/png\",\"sizes\":\"16x16\"}],[\"$\",\"link\",\"13\",{\"rel\":\"icon\",\"href\":\"/icons/favicons/favicon-32x32.png\",\"type\":\"image/png\",\"sizes\":\"32x32\"}],[\"$\",\"link\",\"14\",{\"rel\":\"icon\",\"href\":\"/icons/favicons/android-chrome-192x192.png\",\"type\":\"image/png\",\"sizes\":\"192x192\"}],[\"$\",\"link\",\"15\",{\"rel\":\"icon\",\"href\":\"/icons/favicons/android-chrome-512x512.png\",\"type\":\"image/png\",\"sizes\":\"512x512\"}],[\"$\",\"link\",\"16\",{\"rel\":\"manifest\",\"href\":\"/icons/favicons/site.webmanifest\"}],[\"$\",\"$L4a\",\"17\",{}]]\n"])</script></body></html>